# Flask
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///vpn_portal.db

# WireGuard Server
WG_SERVER_PUBLIC_KEY=<server-public-key-base64>
WG_SERVER_ENDPOINT=vpn.example.com:51820
WG_DNS=1.1.1.1
WG_SUBNET=10.0.0.0/24
WG_SERVER_IP=10.0.0.1
WG_INTERFACE=wg0

# Development mode: skip all real wg commands
WG_DEV_MODE=true

# Rate limiting (Redis URL or memory://)
RATELIMIT_STORAGE_URL=memory://

# Admin user seeded by: flask seed-admin (override before first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
